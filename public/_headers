# ── Cloudflare Pages headers ──
# Assets with content hash — cache forever at edge + browser
/assets/*
  Cache-Control: public, max-age=31536000, s-maxage=31536000, immutable

# Audio files — cache for 1 year (re-encode if updated)
*.opus
  Cache-Control: public, max-age=31536000, s-maxage=31536000, immutable

# Font files — cache for 1 year (content-hashed by Vite)
*.woff2
  Cache-Control: public, max-age=31536000, s-maxage=31536000, immutable

# index.html — NEVER cache (browser + CDN edge must always fetch fresh)
/index.html
  Cache-Control: public, max-age=0, s-maxage=0, must-revalidate, no-cache, no-store
  X-Nginx-Cache-Status: BYPASS

# Root / — same as index.html (Cloudflare resolves / to /index.html)
/
  Cache-Control: public, max-age=0, s-maxage=0, must-revalidate, no-cache, no-store
  X-Nginx-Cache-Status: BYPASS

# All other HTML (404, etc) — never cache
/*.html
  Cache-Control: public, max-age=0, s-maxage=0, must-revalidate, no-cache, no-store
